FROM tracks t
JOIN episodes e ON t.episode_id = e.episode_id
WHERE
--  t.artist LIKE '%Craig%' 
--  AND 
t.track_title LIKE '%More Than Love%'
 -- AND e.episode_name LIKE '%Only 445%'
ORDER BY e.episode_name DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
